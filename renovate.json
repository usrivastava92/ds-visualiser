{
  "extends": [
    "config:base",
    "group:allNonMajor"
  ],
  "schedule": ["on saturday"],
  "timezone": "Asia/Kolkata",
  "labels": ["dependencies"],
  "prHourlyLimit": 10,
  "prConcurrentLimit": 10,
  "automerge": true,
  "automergeType": "branch",
  "rebaseWhen": "auto",
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    }
  ],
  "requiredStatusChecks": null
}
